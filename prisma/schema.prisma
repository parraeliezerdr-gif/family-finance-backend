generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AccountType {
  BANK
  CASH
  CREDIT_CARD
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  LOAN_RECEIVED
  LOAN_GIVEN
  CREDIT_CARD_PAYMENT
}

enum PeriodType {
  WEEKLY
  MONTHLY
  YEARLY
}

enum GoalStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Profile {
  id           String   @id @default(uuid())
  authUserId   String   @unique
  email        String   @unique
  fullName     String?
  avatarUrl    String?
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  HouseholdMember[]
  transactions Transaction[]

  @@map("profiles")
}

model Household {
  id        String   @id @default(uuid())
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      HouseholdMember[]
  invitations  Invitation[]
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  goals        Goal[]

  @@map("households")
}

model HouseholdMember {
  id String @id @default(uuid())

  profileId   String
  householdId String

  role HouseholdRole @default(MEMBER)

  joinedAt DateTime @default(now())

  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([profileId, householdId])

  @@map("household_members")
}

model Invitation {
  id String @id @default(uuid())

  householdId String

  email String

  role HouseholdRole

  status InvitationStatus @default(PENDING)

  expiresAt DateTime

  createdAt DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Account {
  id String @id @default(uuid())

  householdId String

  name String

  type AccountType

  currencyCode String @default("COP")

  initialBalance Decimal @db.Decimal(18, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@map("accounts")
}

model Category {
  id String @id @default(uuid())

  householdId String

  name String

  icon String?
  color String?

  isDefault Boolean @default(false)

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  splits  TransactionSplit[]
  budgets Budget[]

  @@unique([householdId, name])

  @@map("categories")
}

model Transaction {
  id String @id @default(uuid())

  householdId String

  createdById String

  accountId String

  type TransactionType

  amount Decimal @db.Decimal(18, 2)

  description String?

  attachmentUrl String?

  transactionDate DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdBy Profile @relation(fields: [createdById], references: [id], onDelete: Cascade)

  splits TransactionSplit[]

  @@map("transactions")
}

model TransactionSplit {
  id String @id @default(uuid())

  transactionId String

  categoryId String?

  amount Decimal @db.Decimal(18, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("transaction_splits")
}

model Budget {
  id String @id @default(uuid())

  householdId String
  categoryId  String

  amount Decimal @db.Decimal(18, 2)

  periodType PeriodType @default(MONTHLY)

  startDate DateTime
  endDate   DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

model Goal {
  id String @id @default(uuid())

  householdId String

  name        String
  description String?

  targetAmount  Decimal @db.Decimal(18, 2)
  currentAmount Decimal @db.Decimal(18, 2) @default(0)

  targetDate DateTime?

  status GoalStatus @default(IN_PROGRESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("goals")
}
